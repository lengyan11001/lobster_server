    "comfly_veo_skill": {
      "name": "爆款TVC",
      "description": "用一张商品/主图自动做多分镜 + 多段 Veo 成片，可选拼接为一条 TVC；用户对话里可说「用爆款TVC和这个素材做个视频」。技能卡片**必须**在本账号下配置 Comfly 的 API Key 与 API 根地址（每用户独立，不走服务端环境变量兜底），分镜、提示词、模型与拼接由技能内置流程完成，无需用户在卡片里改流水线参数。下方 package_config 中的模型字段仅供系统/高级覆盖，普通用户可忽略。无需算力解锁。技术说明：提示词走 OpenAI 兼容 chat（根地址常为 https://ai.comfly.org）；视频任务走 Comfly v2（POST /v2/videos/generations，以官方文档为准）。",
      "type": "builtin",
      "store_visibility": "online",
      "default_installed": true,
      "status": "available",
      "package_config": {
        "comfly_api_base": "https://ai.comfly.org",
        "video_model": "veo3.1",
        "analysis_model": "gemini-2.5-pro",
        "aspect_ratio": "9:16",
        "enhance_prompt": true,
        "storyboard_image_model": "nano-banana-2",
        "image_request_style": "openai_images"
      },
      "capabilities": {
        "comfly.daihuo": {
          "description": "（单段/分步调试）Comfly + Veo 图生视频：invoke_capability(capability_id=comfly.daihuo，payload.action=upload|generate_prompts|submit_video|poll_video)。成片优先用 comfly.daihuo.pipeline。",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "upload",
                  "generate_prompts",
                  "submit_video",
                  "poll_video"
                ],
                "description": "upload: 本机 asset_id 上传得 image_url；generate_prompts: 从 image_url 生成 5 条英文视频 prompt；submit_video: 提交 Veo 任务；poll_video: 查询 task_id 状态与 output"
              },
              "asset_id": {
                "type": "string",
                "description": "upload 时必填"
              },
              "image_url": {
                "type": "string",
                "description": "generate_prompts/submit_video 时可用"
              },
              "prompt": {
                "type": "string",
                "description": "submit_video 视频提示词"
              },
              "task_id": {
                "type": "string",
                "description": "poll_video 必填"
              },
              "video_model": {
                "type": "string",
                "description": "覆盖卡片默认 Veo 模型"
              },
              "analysis_model": {
                "type": "string",
                "description": "覆盖卡片默认分析模型"
              },
              "aspect_ratio": {
                "type": "string",
                "description": "如 9:16、16:9"
              },
              "enhance_prompt": {
                "type": "boolean",
                "description": "非英文 prompt 时是否增强"
              }
            },
            "required": [
              "action"
            ]
          }
        },
        "comfly.daihuo.pipeline": {
          "description": "爆款TVC 整包成片：action=start_pipeline + asset_id（或 image_url）+ auto_save=true 即可，MCP 自动轮询至完成并入库；run_pipeline 为同步长请求；poll_pipeline+job_id 查进度。",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
