.chat-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 28rpx 28rpx 236rpx;
  color: #f8fafc;
  background:
    radial-gradient(circle at 52% 8%, rgba(34, 211, 238, 0.26) 0, rgba(14, 165, 233, 0.12) 24%, transparent 48%),
    radial-gradient(circle at 12% 42%, rgba(16, 245, 221, 0.12) 0, transparent 36%),
    linear-gradient(180deg, #050914 0%, #020403 100%);
}

.chat-stars {
  position: absolute;
  pointer-events: none;
}

.stars-a {
  left: 0;
  right: 0;
  top: 0;
  height: 100%;
  background-image: radial-gradient(circle, rgba(255,255,255,0.72) 0 2rpx, transparent 3rpx);
  background-size: 124rpx 156rpx;
  opacity: 0.28;
}

.stars-b {
  left: -24%;
  right: -24%;
  top: 140rpx;
  height: 980rpx;
  background-image: radial-gradient(circle, rgba(34,211,238,0.72) 0 2rpx, transparent 4rpx);
  background-size: 230rpx 210rpx;
  opacity: 0.14;
}

.chat-header,
.quick-row,
.auth-section,
.empty,
.message-list {
  position: relative;
  z-index: 1;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 28rpx;
  background:
    linear-gradient(135deg, rgba(24, 34, 48, 0.96), rgba(8, 12, 18, 0.94)),
    radial-gradient(circle at 14% 0, rgba(16, 245, 221, 0.18), transparent 42%);
  border: 1rpx solid rgba(16, 245, 221, 0.2);
  border-radius: 30rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.1);
}

.chat-title,
.chat-subtitle {
  display: block;
}

.chat-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.chat-subtitle {
  margin-top: 10rpx;
  color: rgba(226, 232, 240, 0.62);
  font-size: 23rpx;
}

.header-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.status-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 42rpx;
  padding: 0 14rpx;
  color: rgba(255,255,255,0.58);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  background: #64748b;
  border-radius: 999rpx;
}

.status-pill.online {
  color: #10f5dd;
  background: rgba(16, 245, 221, 0.12);
  border-color: rgba(16, 245, 221, 0.38);
}

.status-pill.online .status-dot {
  background: #10f5dd;
  box-shadow: 0 0 16rpx rgba(16, 245, 221, 0.8);
}

.mini-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 56rpx;
  padding: 0;
  color: #061312;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.quick-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 20rpx 0;
}

.quick-row button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 118rpx;
  padding: 12rpx 6rpx;
  color: #fff;
  background: linear-gradient(180deg, rgba(31, 31, 34, 0.96), rgba(10, 10, 10, 0.94));
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 24rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.12);
  font-size: 22rpx;
  font-weight: 900;
}

.quick-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 8rpx;
  color: #10f5dd;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 16rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.auth-section {
  margin-top: 18rpx;
  padding: 24rpx;
  background: rgba(20, 20, 20, 0.92);
  border: 1rpx solid rgba(255,255,255,0.16);
  border-radius: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 10rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.muted {
  color: rgba(226, 232, 240, 0.58);
  font-size: 23rpx;
  line-height: 1.55;
}

.button-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.primary-btn,
.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.primary-btn {
  color: #061312;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
}

.ghost-btn {
  color: rgba(255,255,255,0.84);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.sms-link {
  margin-top: 18rpx;
  padding: 0;
  color: rgba(16, 245, 221, 0.88);
  text-align: left;
  background: transparent;
  font-size: 22rpx;
  font-weight: 800;
}

.sms-bind-box {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.sms-code-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 128rpx;
  gap: 12rpx;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 76rpx;
  padding: 0 22rpx;
  color: #fff;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 22rpx;
  font-size: 24rpx;
}

.sms-code-btn,
.sms-submit {
  min-height: 76rpx;
  padding: 0 16rpx;
  font-size: 23rpx;
}

.sms-code-btn[disabled] {
  color: rgba(255,255,255,0.38);
  background: rgba(255,255,255,0.05);
}

.sms-submit {
  width: 100%;
}

.empty {
  margin-top: 28rpx;
  padding: 72rpx 24rpx;
  color: rgba(226, 232, 240, 0.58);
  text-align: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 28rpx;
  font-size: 26rpx;
}

.message-list {
  margin-top: 18rpx;
}

.message-card {
  margin-top: 26rpx;
}

.message-label {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(226, 232, 240, 0.45);
  font-size: 20rpx;
  font-weight: 900;
}

.user-label {
  margin-left: 88rpx;
  text-align: right;
}

.reply-label {
  margin-top: 14rpx;
}

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.58;
}

.user-bubble {
  margin-left: 82rpx;
  color: #041011;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
  border-bottom-right-radius: 8rpx;
  font-weight: 700;
}

.reply-bubble {
  margin-right: 52rpx;
  color: rgba(255,255,255,0.86);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-bottom-left-radius: 8rpx;
}

.media-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.media-card {
  min-width: 0;
  padding: 14rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 22rpx;
}

.preview {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  background: #0f172a;
  border-radius: 16rpx;
}

.image-preview {
  background: rgba(255,255,255,0.06);
}

.video-preview {
  display: block;
}

.file-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220rpx;
  color: rgba(226, 232, 240, 0.58);
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
}

.media-title {
  display: block;
  overflow: hidden;
  margin-top: 12rpx;
  color: rgba(255,255,255,0.76);
  font-size: 22rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.media-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 12rpx;
}

.media-actions .primary-btn,
.media-actions .ghost-btn {
  min-height: 60rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
}

.composer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 116rpx;
  gap: 14rpx;
  align-items: end;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(4, 7, 12, 0.96);
  border-top: 1rpx solid rgba(255,255,255,0.1);
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.34);
}

.message-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 82rpx;
  max-height: 210rpx;
  padding: 20rpx 22rpx;
  color: #fff;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.message-placeholder {
  color: rgba(226, 232, 240, 0.42);
}

.send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin: 0;
  padding: 0;
  color: #061312;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 900;
}
