.home-hero {
  padding-bottom: 30rpx;
}

.hero-actions {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.light-btn,
.outline-light-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.light-btn {
  color: #0f172a;
  background: #fff;
}

.outline-light-btn {
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.inline-title {
  margin-bottom: 0;
}

.status-text {
  display: block;
  margin-top: 18rpx;
  color: #334155;
  font-size: 28rpx;
}

.bind-tip,
.check-result {
  display: block;
  margin-top: 18rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.quick-card {
  display: block;
  min-height: 174rpx;
  padding: 22rpx;
  text-align: left;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 22rpx;
}

.quick-title {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.quick-text {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}

.slim-section {
  padding-bottom: 22rpx;
}
