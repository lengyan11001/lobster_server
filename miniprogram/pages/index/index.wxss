}

.template-title,
.template-sub {
  position: absolute;
  z-index: 3;
  left: 18rpx;
  right: 18rpx;
  display: block;
  overflow: hidden;
  color: #fff;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.5);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-title {
  bottom: 48rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.template-sub {
  bottom: 18rpx;
  font-size: 19rpx;
  color: rgba(255,255,255,0.72);
}

.video-feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.video-feature {
  position: relative;
  overflow: hidden;
  min-height: 210rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: #111827;
}

.feature-bg,
.feature-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.feature-bg {
  transform: scale(1.02);
}

.feature-mask {
  background:
    linear-gradient(135deg, rgba(0, 0, 0, 0.68) 0%, rgba(0, 0, 0, 0.36) 52%, rgba(0, 0, 0, 0.08) 100%),
    linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0));
}

.feature-copy {
  position: relative;
  z-index: 1;
}

.video-feature text {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.video-feature text + text {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.64);
  font-size: 22rpx;
}

.image-gen {
  background: #22130a;
}

.video-gen {
  background: #071426;
}

.bottom-space {
  height: 56rpx;
}
