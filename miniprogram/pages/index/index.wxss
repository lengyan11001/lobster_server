page {
  background: #020403;
}

.home-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 26rpx 36rpx 0;
  color: #f8fafc;
  background:
    radial-gradient(circle at 52% 22%, rgba(146, 164, 196, 0.5) 0, rgba(39, 64, 101, 0.26) 16%, rgba(7, 15, 28, 0) 38%),
    radial-gradient(circle at 45% 58%, rgba(37, 99, 235, 0.24) 0, rgba(20, 184, 166, 0.1) 24%, rgba(0, 0, 0, 0) 45%),
    linear-gradient(180deg, #050914 0%, #030504 48%, #020403 100%);
}

.home-shell::before {
  content: "";
  position: absolute;
  left: -10%;
  right: -10%;
  top: 0;
  height: 780rpx;
  opacity: 0.82;
  background:
    radial-gradient(circle at 18% 14%, #ffffff 0 2rpx, transparent 4rpx),
    radial-gradient(circle at 78% 10%, #ffffff 0 2rpx, transparent 4rpx),
    radial-gradient(circle at 66% 28%, rgba(255,255,255,0.9) 0 2rpx, transparent 4rpx),
    radial-gradient(circle at 28% 36%, rgba(255,255,255,0.8) 0 2rpx, transparent 4rpx),
    radial-gradient(circle at 84% 45%, rgba(255,255,255,0.86) 0 2rpx, transparent 4rpx),
    radial-gradient(circle at 45% 12%, rgba(34,211,238,0.7) 0 2rpx, transparent 5rpx);
}

.space-layer {
  position: absolute;
  pointer-events: none;
}

.stars-a {
  left: 0;
  right: 0;
  top: 0;
  height: 100%;
  background-image: radial-gradient(circle, rgba(255,255,255,0.75) 0 2rpx, transparent 3rpx);
  background-size: 116rpx 152rpx;
  opacity: 0.38;
}

.stars-b {
  left: -20%;
  right: -20%;
  top: 160rpx;
  height: 960rpx;
  background-image: radial-gradient(circle, rgba(34,211,238,0.7) 0 2rpx, transparent 4rpx);
  background-size: 230rpx 210rpx;
  opacity: 0.18;
}

.home-top,
.brand-stage,
.clone-card,
.tool-grid,
.wide-card,
.disabled-card,
.task-card,
.showcase-section {
  position: relative;
  z-index: 1;
}

.home-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 6rpx;
}

.hello-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  max-width: 390rpx;
  height: 54rpx;
  padding: 0 22rpx;
  color: rgba(255,255,255,0.86);
  background: rgba(31, 41, 55, 0.82);
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.hello-pill text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-dot {
  flex: 0 0 12rpx;
  width: 12rpx;
  height: 12rpx;
  background: #64748b;
  border-radius: 999rpx;
}

.status-dot.online {
  background: #10f5dd;
  box-shadow: 0 0 18rpx rgba(16, 245, 221, 0.8);
}

.profile-bubble {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 92rpx;
  height: 64rpx;
  padding: 0;
  color: #fff;
  background: rgba(31, 41, 55, 0.66);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.brand-stage {
  height: 690rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: -96rpx -36rpx 0;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 690rpx;
  opacity: 0.94;
  z-index: 0;
}

.hero-lobster {
  position: absolute;
  left: 50%;
  top: 82rpx;
  width: 470rpx;
  height: 530rpx;
  margin-left: -235rpx;
  filter: drop-shadow(0 24rpx 42rpx rgba(0, 245, 221, 0.22));
  animation: heroFloat 6s ease-in-out infinite;
  z-index: 2;
}

.hero-vignette {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1;
  background:
    linear-gradient(180deg, rgba(2, 4, 3, 0.12) 0%, rgba(2, 4, 3, 0.04) 40%, rgba(2, 4, 3, 0.96) 100%),
    radial-gradient(circle at 50% 38%, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.28) 72%);
}

.planet-glow {
  position: absolute;
  left: 18%;
  right: 18%;
  bottom: 70rpx;
  height: 120rpx;
  border-radius: 50% 50% 0 0;
  background: radial-gradient(ellipse at center, rgba(34, 211, 238, 0.36) 0, rgba(30, 64, 175, 0.18) 42%, transparent 76%);
  filter: blur(1rpx);
  z-index: 1;
}

.brand-line {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 142rpx;
  z-index: 3;
  color: rgba(255,255,255,0.68);
  font-size: 26rpx;
  letter-spacing: 6rpx;
  text-align: center;
}

.clone-card {
  display: flex;
  align-items: center;
  min-height: 150rpx;
  padding: 34rpx;
  background: linear-gradient(135deg, rgba(55, 57, 66, 0.92), rgba(30, 31, 38, 0.9));
  border: 1rpx solid rgba(255,255,255,0.28);
  border-radius: 34rpx;
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.28);
  margin-top: -108rpx;
}

.clone-copy {
  flex: 1;
  min-width: 0;
}

.clone-title-row,
.wide-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.clone-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.active-badge,
.new-badge,
.soon-badge {
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 16rpx;
  color: #10f5dd;
  background: rgba(20, 184, 166, 0.14);
  border: 1rpx solid rgba(20, 245, 221, 0.6);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.clone-sub {
  display: block;
  margin-top: 12rpx;
  color: rgba(255,255,255,0.84);
  font-size: 20rpx;
  letter-spacing: 10rpx;
}

.clone-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(226, 232, 240, 0.66);
  font-size: 23rpx;
}

.clone-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  color: #fff;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.16);
  border-radius: 999rpx;
  font-size: 54rpx;
  line-height: 1;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.tool-card {
  min-width: 0;
  min-height: 132rpx;
  padding: 14rpx 6rpx 10rpx;
  color: #fff;
  background: linear-gradient(180deg, rgba(31, 31, 34, 0.96), rgba(10, 10, 10, 0.94));
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 26rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.12);
}

.tool-icon,
.tool-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 10rpx;
  color: #fff;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.16);
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.tool-icon {
  position: relative;
}

.video-icon::after,
.image-icon::after,
.copy-icon::after {
  position: absolute;
  left: 50%;
  top: 50%;
  color: #fff;
  transform: translate(-50%, -50%);
  font-size: 34rpx;
  font-weight: 900;
}

.video-icon::after {
  content: "▶";
}

.image-icon::after {
  content: "▧";
}

.copy-icon::after {
  content: "✎";
}

.tool-title {
  display: block;
  overflow: hidden;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-sub {
  display: block;
  margin-top: 6rpx;
  color: rgba(148, 163, 184, 0.58);
  font-size: 14rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  text-align: center;
}

.wide-card,
.disabled-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 106rpx;
  margin-top: 20rpx;
  padding: 18rpx 26rpx;
  background: rgba(20, 20, 20, 0.92);
  border: 1rpx solid rgba(255,255,255,0.24);
  border-radius: 28rpx;
}

.disabled-card {
  opacity: 0.58;
}

.wide-icon,
.disabled-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 68rpx;
  width: 68rpx;
  height: 68rpx;
  color: #10f5dd;
  background: rgba(255,255,255,0.13);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.wide-copy {
  flex: 1;
  min-width: 0;
}

.wide-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.new-badge {
  color: #fff;
  background: linear-gradient(135deg, #22d3ee, #7c3aed);
  border: 0;
}

.soon-badge {
  color: #f5d0fe;
  background: rgba(126, 34, 206, 0.5);
  border: 1rpx solid rgba(216, 180, 254, 0.32);
}

.wide-sub {
  display: block;
  margin-top: 8rpx;
  color: rgba(226, 232, 240, 0.58);
  font-size: 22rpx;
}

.wide-arrow {
  color: rgba(255,255,255,0.48);
  font-size: 40rpx;
  font-weight: 900;
}

.muted-title {
  color: rgba(255,255,255,0.72);
}

.task-card {
  margin-top: 20rpx;
  padding: 24rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(18, 29, 34, 0.96), rgba(8, 12, 18, 0.96)),
    radial-gradient(circle at 16% 0, rgba(16, 245, 221, 0.14), transparent 36%);
  border: 1rpx solid rgba(16, 245, 221, 0.2);
  border-radius: 28rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.1);
}

.task-card-summary {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.task-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 68rpx;
  width: 68rpx;
  height: 68rpx;
  color: #10f5dd;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 22rpx;
  font-size: 30rpx;
}

.task-copy {
  flex: 1;
  min-width: 0;
}

.task-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.task-status {
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 12rpx;
  color: rgba(255,255,255,0.62);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 900;
}

.task-status.online {
  color: #10f5dd;
  background: rgba(16, 245, 221, 0.12);
  border-color: rgba(16, 245, 221, 0.38);
}

.task-sub {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: rgba(226, 232, 240, 0.58);
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-toggle,
.task-primary-btn,
.task-ghost-btn,
.task-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.task-toggle,
.task-primary-btn,
.task-submit {
  color: #061312;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
  box-shadow: 0 12rpx 30rpx rgba(16, 245, 221, 0.18);
}

.task-toggle {
  flex: 0 0 104rpx;
  min-height: 56rpx;
  padding: 0;
  font-size: 22rpx;
}

.task-panel {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.auth-card {
  padding: 22rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
}

.auth-title,
.task-field-label {
  display: block;
  color: rgba(255,255,255,0.9);
  font-size: 24rpx;
  font-weight: 900;
}

.auth-text {
  display: block;
  margin-top: 10rpx;
  color: rgba(226, 232, 240, 0.58);
  font-size: 22rpx;
  line-height: 1.45;
}

.auth-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.task-ghost-btn {
  color: rgba(255,255,255,0.84);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.sms-link {
  margin-top: 18rpx;
  padding: 0;
  color: rgba(16, 245, 221, 0.88);
  background: transparent;
  font-size: 22rpx;
  font-weight: 800;
  text-align: left;
}

.sms-bind-box {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.sms-code-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 128rpx;
  gap: 12rpx;
}

.sms-code-btn[disabled] {
  color: rgba(255,255,255,0.38);
  background: rgba(255,255,255,0.05);
}

.sms-submit,
.task-submit {
  width: 100%;
}

.task-field {
  margin-top: 22rpx;
}

.task-field:first-child {
  margin-top: 0;
}

.task-seg {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 12rpx;
  padding: 6rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 22rpx;
}

.task-seg button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 64rpx;
  padding: 0 12rpx;
  color: rgba(226, 232, 240, 0.62);
  background: transparent;
  border-radius: 18rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.task-seg button.active {
  color: #061312;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
}

.task-input {
  box-sizing: border-box;
  width: 100%;
  height: 76rpx;
  margin-top: 12rpx;
  padding: 0 22rpx;
  color: #fff;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 22rpx;
  font-size: 24rpx;
}

.interval-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 72rpx;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sms-code-row .task-input,
.interval-row .task-input {
  margin-top: 0;
}

.interval-row text {
  color: rgba(226, 232, 240, 0.58);
  font-size: 23rpx;
}

.digital-fields {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 12rpx;
  margin-top: 22rpx;
}

.digital-fields picker {
  min-width: 0;
}

.picker-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 76rpx;
  padding: 0 20rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 22rpx;
}

.picker-label {
  flex: 0 0 auto;
  color: rgba(226, 232, 240, 0.52);
  font-size: 22rpx;
  font-weight: 800;
}

.picker-value {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: rgba(255,255,255,0.86);
  font-size: 23rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.auto-btn {
  grid-column: 2;
  grid-row: 1 / 3;
  min-height: 76rpx;
  padding: 0 14rpx;
  border-radius: 22rpx;
}

.task-submit {
  margin-top: 24rpx;
  height: 78rpx;
  font-size: 26rpx;
}

.showcase-section {
  margin-top: 40rpx;
}

@keyframes heroFloat {
  0%, 100% {
    transform: scale(1) translateY(0);
  }
  50% {
    transform: scale(1.025) translateY(-16rpx);
  }
}

.showcase-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.showcase-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
}

.showcase-head button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  padding: 0 22rpx;
  color: rgba(255,255,255,0.58);
  background: rgba(255,255,255,0.06);
  border-radius: 999rpx;
  font-size: 22rpx;
}

.showcase-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.showcase-strip {
  display: flex;
  gap: 18rpx;
  padding: 4rpx 0 10rpx;
}

.start-template {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 0 0 90rpx;
  height: 300rpx;
  color: rgba(255,255,255,0.78);
  background: linear-gradient(180deg, #3f3f46, #171717);
  border: 1rpx solid rgba(255,255,255,0.16);
  border-radius: 38rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.plus-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.34);
  border-radius: 999rpx;
  font-size: 38rpx;
  font-weight: 300;
}

.template-card {
  position: relative;
  flex: 0 0 214rpx;
  height: 300rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: linear-gradient(180deg, #1f2937, #020617);
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 18rpx 42rpx rgba(0,0,0,0.28);
}

.template-card::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 52%;
  background: linear-gradient(180deg, transparent, rgba(0,0,0,0.72));
}

.template-img,
.template-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.template-img {
  z-index: 0;
  transform: scale(1.01);
}

.template-mask {
  z-index: 1;
  background:
    linear-gradient(180deg, rgba(0,0,0,0.03) 0%, rgba(0,0,0,0.12) 48%, rgba(0,0,0,0.76) 100%),
    linear-gradient(135deg, rgba(16,245,221,0.08), rgba(0,0,0,0));
}

.template-placeholder,
.template-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.7);
  background: linear-gradient(160deg, #334155, #020617);
  font-size: 54rpx;
  font-weight: 900;
}

.template-static {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 30%, rgba(255,255,255,0.14), transparent 34%),
    linear-gradient(160deg, #122131, #020617 72%);
}

.tone-1 .template-static {
  background:
    radial-gradient(circle at 48% 28%, rgba(45,212,191,0.18), transparent 34%),
    linear-gradient(160deg, #12312f, #020617 72%);
}

.tone-2 .template-static {
  background:
    radial-gradient(circle at 52% 28%, rgba(96,165,250,0.22), transparent 36%),
    linear-gradient(160deg, #10223f, #020617 72%);
}

.tone-3 .template-static {
  background:
    radial-gradient(circle at 50% 30%, rgba(244,114,182,0.18), transparent 35%),
    linear-gradient(160deg, #301728, #020617 72%);
}

.tone-4 .template-static {
  background:
    radial-gradient(circle at 52% 28%, rgba(251,191,36,0.2), transparent 34%),
    linear-gradient(160deg, #34270f, #020617 72%);
}

.tone-5 .template-static {
  background:
    radial-gradient(circle at 50% 28%, rgba(167,139,250,0.2), transparent 34%),
    linear-gradient(160deg, #221c3d, #020617 72%);
}

.avatar-glow {
  position: absolute;
  left: 38rpx;
  right: 38rpx;
  top: 38rpx;
  height: 158rpx;
  border-radius: 999rpx;
  background: rgba(16,245,221,0.12);
  filter: blur(10rpx);
}

.avatar-head {
  position: absolute;
  left: 50%;
  top: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
