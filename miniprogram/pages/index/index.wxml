<view class="home-shell">
  <view class="space-layer stars-a"></view>
  <view class="space-layer stars-b"></view>

  <view class="home-top">
    <view class="hello-pill">
      <view class="status-dot {{phoneBound ? 'online' : ''}}"></view>
      <text wx:if="{{phoneBound}}">你好，{{phone}}</text>
      <text wx:else>你好，小龙虾</text>
    </view>
    <button class="profile-bubble" bindtap="goProfile">{{phoneBound ? '我的' : '授权'}}</button>
  </view>

  <view class="brand-stage">
    <image class="hero-bg" src="/static/openclaw-hero-bg.jpg" mode="aspectFill" />
    <image class="hero-lobster" src="/static/openclaw-lobster.png" mode="aspectFit" />
    <view class="hero-vignette"></view>
    <view class="planet-glow"></view>
    <text class="brand-line">把不凡的创意变成现实</text>
  </view>

  <view class="clone-card" bindtap="goAssistant">
    <view class="clone-copy">
      <view class="clone-title-row">
        <text class="clone-title">AI超级员工</text>
        <text class="active-badge">ACTIVE</text>
      </view>
      <text class="clone-sub">OPENCLAW AI EMPLOYEE</text>
      <text class="clone-desc">点击进入龙虾 OpenClaw 盒子，直接对话安排任务。</text>
    </view>
    <view class="clone-arrow">></view>
  </view>

  <view class="tool-grid">
    <button class="tool-card" data-prompt="帮我生成一个创意短视频方案，并给出可执行的镜头脚本。" bindtap="goFeature">
      <view class="tool-icon video-icon"></view>
      <text class="tool-title">获客创意视频</text>
      <text class="tool-sub">ACQUISITION</text>
    </button>
    <button class="tool-card" data-prompt="帮我生成一张商业设计图，画面适合品牌宣传，风格高级。" bindtap="goFeature">
      <view class="tool-icon image-icon"></view>
      <text class="tool-title">商业设计图</text>
      <text class="tool-sub">COMMERCIAL</text>
    </button>
    <button class="tool-card" data-prompt="帮我写一段适合短视频口播的文案，要求有钩子、有卖点、有转化。" bindtap="goFeature">
      <view class="tool-icon copy-icon"></view>
      <text class="tool-title">文案智能体</text>
      <text class="tool-sub">COPYWRITING</text>
    </button>
    <button class="tool-card" data-prompt="打开更多 AI 员工能力，并根据我的目标推荐下一步。" bindtap="goFeature">
      <view class="tool-avatar">AI</view>
      <text class="tool-title">更多AI</text>
      <text class="tool-sub">持续开发中</text>
    </button>
  </view>

  <view class="wide-card" data-prompt="帮我制作一条短剧广告：先给出爆款脚本，再规划画面和视频生成方案。" bindtap="goFeature">
    <view class="wide-icon">AD</view>
    <view class="wide-copy">
      <view class="wide-title-row">
        <text class="wide-title">短剧广告制作</text>
        <text class="new-badge">NEW</text>
      </view>
      <text class="wide-sub">AI拍电影做广告，一键生成大片</text>
    </view>
    <text class="wide-arrow">></text>
  </view>

  <view class="disabled-card" bindtap="goComingSoon">
    <view class="disabled-icon">AI</view>
    <view class="wide-copy">
      <view class="wide-title-row">
        <text class="wide-title muted-title">AI超级混剪</text>
        <text class="soon-badge">即将上线</text>
      </view>
      <text class="wide-sub">多视频一键成片</text>
    </view>
    <text class="wide-arrow">></text>
  </view>

  <view class="task-card">
    <view class="task-card-summary">
      <view class="task-icon">定</view>
      <view class="task-copy">
        <view class="task-title-row">
          <text class="task-title">定时任务</text>
          <text class="task-status {{phoneBound ? 'online' : ''}}">{{phoneBound ? 'ONLINE' : 'AUTH'}}</text>
        </view>
        <text class="task-sub">{{onlineText}}</text>
      </view>
      <button class="task-toggle" bindtap="toggleTaskPanel">{{taskExpanded ? '收起' : '配置'}}</button>
    </view>

    <view wx:if="{{taskExpanded}}" class="task-panel">
      <view wx:if="{{authPanelVisible && !phoneBound}}" class="auth-card">
        <text class="auth-title">授权后启用定时任务</text>
        <text class="auth-text">{{authHint}}</text>
        <view class="auth-actions">
          <button class="task-ghost-btn" bindtap="login">微信登录</button>
          <button class="task-primary-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">授权手机号</button>
        </view>
        <button class="sms-link" bindtap="showSmsBind">微信取号失败，用短信验证码绑定</button>
        <view wx:if="{{smsBindVisible}}" class="sms-bind-box">
          <input class="task-input" type="number" maxlength="11" value="{{smsPhone}}" bindinput="onSmsPhoneInput" placeholder="输入已开通 online 的手机号" />
          <view class="sms-code-row">
            <input class="task-input" type="number" maxlength="8" value="{{smsCode}}" bindinput="onSmsCodeInput" placeholder="短信验证码" />
            <button class="task-ghost-btn sms-code-btn" disabled="{{smsSending || smsCountdown > 0}}" loading="{{smsSending}}" bindtap="sendSmsCode">{{smsCountdown > 0 ? smsCountdown + 's' : '获取'}}</button>
          </view>
          <button class="task-primary-btn sms-submit" loading="{{smsBinding}}" bindtap="bindBySms">绑定手机号</button>
        </view>
      </view>

      <block wx:else>
        <view class="task-field">
          <text class="task-field-label">AI能力</text>
          <view class="task-seg">
            <button wx:for="{{capabilities}}" wx:key="id" class="{{taskAbility === item.id ? 'active' : ''}}" data-ability="{{item.id}}" bindtap="setTaskAbility">{{item.name}}</button>
          </view>
        </view>

        <view class="task-field">
          <text class="task-field-label">任务名称</text>
          <input class="task-input" value="{{taskTitle}}" bindinput="onTaskTitleInput" placeholder="不填则自动使用能力名称" />
        </view>

        <view class="task-field">
          <text class="task-field-label">执行方式</text>
          <view class="task-seg">
            <button class="{{scheduleType === 'once' ? 'active' : ''}}" data-type="once" bindtap="setScheduleType">一次性</button>
            <button class="{{scheduleType === 'interval' ? 'active' : ''}}" data-type="interval" bindtap="setScheduleType">循环执行</button>
          </view>
        </view>

        <view wx:if="{{scheduleType === 'interval'}}" class="task-field">
          <text class="task-field-label">循环间隔</text>
          <view class="interval-row">
            <input class="task-input" type="number" value="{{intervalMinutes}}" bindinput="onIntervalInput" placeholder="间隔分钟" />
            <text>分钟</text>
          </view>
        </view>

        <view wx:if="{{taskAbility === 'hifly.video.create_by_tts'}}" class="digital-fields">
          <picker mode="selector" range="{{avatarRows}}" range-key="title" value="{{avatarIndex}}" bindchange="onAvatarChange">
            <view class="picker-box">
              <text class="picker-label">数字人</text>
              <text class="picker-value">{{hiflyLoading ? '加载中...' : (selectedAvatarTitle || '请选择')}}</text>
            </view>
          </picker>
          <picker mode="selector" range="{{voiceRows}}" range-key="title" value="{{voiceIndex}}" bindchange="onVoiceChange">
            <view class="picker-box">
              <text class="picker-label">声音</text>
              <text class="picker-value">{{hiflyLoading ? '加载中...' : (selectedVoiceTitle || '请选择')}}</text>
            </view>
          </picker>
          <button class="task-ghost-btn auto-btn" bindtap="autoPickDigital">自动选择</button>
        </view>

        <button class="task-submit" loading="{{submittingTask}}" bindtap="createScheduledTask">下发定时任务</button>
      </block>
    </view>
  </view>

  <view class="showcase-section">
    <view class="showcase-head">
      <text class="showcase-title">AI数字人 · 销冠模板</text>
      <button bindtap="goAvatarTemplates">查看全部 ></button>
    </view>
    <scroll-view scroll-x class="showcase-scroll" show-scrollbar="{{false}}">
      <view class="showcase-strip">
        <view class="start-template" bindtap="goDigital">
          <view class="plus-circle">+</view>
          <text>开始定制</text>
        </view>
        <view wx:if="{{avatarTemplatesLoading && !publicAvatarTemplates.length}}" class="template-card template-loading">
          <view class="template-skeleton"></view>
          <text class="template-title">加载模板中</text>
          <text class="template-sub">公共数字人</text>
        </view>
        <view wx:for="{{publicAvatarTemplates}}" wx:key="avatar" class="template-card" data-index="{{index}}" bindtap="selectPublicAvatarTemplate">
          <image wx:if="{{item.image_url}}" class="template-img" src="{{item.image_url}}" mode="aspectFill" />
          <view wx:else class="template-img template-placeholder">数</view>
          <view class="template-mask"></view>
          <text class="template-title">{{item.title}}</text>
          <text class="template-sub">公共数字人</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="showcase-section">
    <view class="showcase-head">
      <text class="showcase-title">AI视频 · 创意生产</text>
      <button data-prompt="帮我生成一个 AI 视频，从创意、脚本、画面提示词到成片步骤都规划好。" bindtap="goFeature">开始 ></button>
    </view>
    <view class="video-feature-grid">
      <view class="video-feature image-gen" data-prompt="帮我生成一张高质感商业海报图。" bindtap="goFeature">
        <image class="feature-bg" src="/static/ai-image-bg.jpg" mode="aspectFill" />
        <view class="feature-mask"></view>
        <view class="feature-copy">
          <text>AI图片生成</text>
          <text>商业设计</text>
        </view>
      </view>
      <view class="video-feature video-gen" data-prompt="帮我生成一个 10 秒品牌宣传视频。" bindtap="goFeature">
        <image class="feature-bg" src="/static/ai-video-bg.jpg" mode="aspectFill" />
        <view class="feature-mask"></view>
        <view class="feature-copy">
          <text>AI视频生成</text>
          <text>创意成片</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
