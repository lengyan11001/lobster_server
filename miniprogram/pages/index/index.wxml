<view class="home-shell">
  <view class="space-layer stars-a"></view>
  <view class="space-layer stars-b"></view>

  <view class="home-top">
    <view class="hello-pill">
      <view class="status-dot {{phoneBound ? 'online' : ''}}"></view>
      <text wx:if="{{phoneBound}}">你好，{{phone}}</text>
      <text wx:else>你好，小龙虾</text>
    </view>
    <button class="profile-bubble" bindtap="goProfile">{{phoneBound ? '我的' : '授权'}}</button>
  </view>

  <view class="brand-stage">
    <image class="hero-art" src="/static/openclaw-hero.jpg" mode="aspectFit" />
    <view class="hero-vignette"></view>
    <view class="planet-glow"></view>
    <view class="brand-orbit">
      <view class="orbit-ring ring-a"></view>
      <view class="orbit-ring ring-b"></view>
      <text class="brand-mark">OPENCLAW</text>
      <text class="brand-name">龙虾AI</text>
    </view>
    <text class="brand-line">把不凡的创意变成现实</text>
  </view>

  <view class="clone-card" bindtap="goAssistant">
    <view class="clone-copy">
      <view class="clone-title-row">
        <text class="clone-title">AI超级员工</text>
        <text class="active-badge">ACTIVE</text>
      </view>
      <text class="clone-sub">OPENCLAW AI EMPLOYEE</text>
      <text class="clone-desc">点击进入龙虾 OpenClaw 盒子，直接对话安排任务。</text>
    </view>
    <view class="clone-arrow">></view>
  </view>

  <view class="tool-grid">
    <button class="tool-card" data-prompt="帮我生成一个创意短视频方案，并给出可执行的镜头脚本。" bindtap="goFeature">
      <view class="tool-icon video-icon"></view>
      <text class="tool-title">获客创意视频</text>
      <text class="tool-sub">ACQUISITION</text>
    </button>
    <button class="tool-card" data-prompt="帮我生成一张商业设计图，画面适合品牌宣传，风格高级。" bindtap="goFeature">
      <view class="tool-icon image-icon"></view>
      <text class="tool-title">商业设计图</text>
      <text class="tool-sub">COMMERCIAL</text>
    </button>
    <button class="tool-card" data-prompt="帮我写一段适合短视频口播的文案，要求有钩子、有卖点、有转化。" bindtap="goFeature">
      <view class="tool-icon copy-icon"></view>
      <text class="tool-title">文案智能体</text>
      <text class="tool-sub">COPYWRITING</text>
    </button>
    <button class="tool-card" data-prompt="打开更多 AI 员工能力，并根据我的目标推荐下一步。" bindtap="goFeature">
      <view class="tool-avatar">AI</view>
      <text class="tool-title">更多AI</text>
      <text class="tool-sub">持续开发中</text>
    </button>
  </view>

  <view class="wide-card" data-prompt="帮我制作一条短剧广告：先给出爆款脚本，再规划画面和视频生成方案。" bindtap="goFeature">
    <view class="wide-icon">AD</view>
    <view class="wide-copy">
      <view class="wide-title-row">
        <text class="wide-title">短剧广告制作</text>
        <text class="new-badge">NEW</text>
      </view>
      <text class="wide-sub">AI拍电影做广告，一键生成大片</text>
    </view>
    <text class="wide-arrow">></text>
  </view>

  <view class="disabled-card" bindtap="goComingSoon">
    <view class="disabled-icon">AI</view>
    <view class="wide-copy">
      <view class="wide-title-row">
        <text class="wide-title muted-title">AI超级混剪</text>
        <text class="soon-badge">即将上线</text>
      </view>
      <text class="wide-sub">多视频一键成片</text>
    </view>
    <text class="wide-arrow">></text>
  </view>

  <view class="showcase-section">
    <view class="showcase-head">
      <text class="showcase-title">AI数字人 · 销冠模板</text>
      <button bindtap="goDigital">查看全部 ></button>
    </view>
    <scroll-view scroll-x class="showcase-scroll" show-scrollbar="{{false}}">
      <view class="showcase-strip">
        <view class="start-template" bindtap="goDigital">
          <view class="plus-circle">+</view>
          <text>开始定制</text>
        </view>
        <view class="template-card person-a" bindtap="goDigital">
          <text class="template-title">销冠口播</text>
          <text class="template-sub">数字人分身</text>
        </view>
        <view class="template-card person-b" bindtap="goDigital">
          <text class="template-title">品牌讲解</text>
          <text class="template-sub">AI员工上镜</text>
        </view>
        <view class="template-card person-c" bindtap="goDigital">
          <text class="template-title">知识带货</text>
          <text class="template-sub">文案驱动视频</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="showcase-section">
    <view class="showcase-head">
      <text class="showcase-title">AI视频 · 创意生产</text>
      <button data-prompt="帮我生成一个 AI 视频，从创意、脚本、画面提示词到成片步骤都规划好。" bindtap="goFeature">开始 ></button>
    </view>
    <view class="video-feature-grid">
      <view class="video-feature image-gen" data-prompt="帮我生成一张高质感商业海报图。" bindtap="goFeature">
        <image class="feature-bg" src="/static/ai-image-bg.jpg" mode="aspectFill" />
        <view class="feature-mask"></view>
        <view class="feature-copy">
          <text>AI图片生成</text>
          <text>商业设计</text>
        </view>
      </view>
      <view class="video-feature video-gen" data-prompt="帮我生成一个 10 秒品牌宣传视频。" bindtap="goFeature">
        <image class="feature-bg" src="/static/ai-video-bg.jpg" mode="aspectFill" />
        <view class="feature-mask"></view>
        <view class="feature-copy">
          <text>AI视频生成</text>
          <text>创意成片</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
