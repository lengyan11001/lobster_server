.digital-page {
  padding-bottom: 70rpx;
}

.digital-hero {
  background: linear-gradient(135deg, #111827 0%, #1d4ed8 54%, #10b981 100%);
}

.hero-kicker {
  position: relative;
  z-index: 1;
  display: block;
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
  font-weight: 800;
}

.inline-title {
  margin-bottom: 0;
}

.selected-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
}

.selected-box {
  min-width: 0;
  padding: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 18rpx;
}

.selected-label,
.asset-tag,
.video-meta {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.selected-value {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.title-input {
  margin-top: 18rpx;
}

.script-input {
  width: 100%;
  min-height: 260rpx;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  color: #0f172a;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
}

.option-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.create-btn {
  width: 100%;
  margin-top: 18rpx;
}

.progress-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  color: #1d4ed8;
  background: #eff6ff;
  border-radius: 18rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.spinner {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #bfdbfe;
  border-top-color: #2563eb;
  border-radius: 999rpx;
}

.asset-tabs,
.sub-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.sub-tabs {
  margin-top: 16rpx;
}

.asset-tabs button,
.sub-tabs button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 70rpx;
  color: #334155;
  background: #f1f5f9;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.asset-tabs button.active,
.sub-tabs button.active {
  color: #fff;
  background: #2563eb;
}

.asset-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.asset-strip {
  display: flex;
  gap: 18rpx;
  padding: 4rpx 2rpx 8rpx;
}

.avatar-card {
  flex: 0 0 210rpx;
  width: 210rpx;
  padding: 12rpx;
  background: #f8fafc;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
}

.avatar-card.selected,
.voice-card.selected {
  border-color: #2563eb;
  background: #eff6ff;
}

.avatar-image,
.avatar-placeholder {
  display: block;
  width: 186rpx;
  height: 240rpx;
  border-radius: 16rpx;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(135deg, #1d4ed8, #10b981);
  font-size: 54rpx;
  font-weight: 900;
}

.asset-title {
  display: block;
  margin-top: 12rpx;
  overflow: hidden;
  color: #0f172a;
  font-size: 25rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.voice-list,
.video-list {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.voice-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx;
  background: #f8fafc;
  border: 2rpx solid transparent;
  border-radius: 18rpx;
}

.voice-main {
  flex: 1;
  min-width: 0;
}

.voice-title {
  display: block;
  overflow: hidden;
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.play-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 100rpx;
  height: 58rpx;
  min-height: 58rpx;
  padding: 0;
  color: #1d4ed8;
  background: #dbeafe;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
}

.video-card {
  display: grid;
  grid-template-columns: 180rpx minmax(0, 1fr);
  gap: 18rpx;
  padding: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 20rpx;
}

.video-thumb {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #0f172a, #1d4ed8);
  border-radius: 16rpx;
}

.video-state {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 6rpx 12rpx;
  color: #fff;
  background: rgba(15, 23, 42, 0.72);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.video-state.success {
  background: #16a34a;
}

.video-state.failed {
  background: #dc2626;
}

.play-mark {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.video-info {
  min-width: 0;
}

.video-title {
  display: block;
  overflow: hidden;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-error {
  display: block;
  margin-top: 8rpx;
  color: #b91c1c;
  font-size: 22rpx;
}

.video-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.video-actions button {
  height: 54rpx;
  padding: 0 18rpx;
  color: #1d4ed8;
  background: #eff6ff;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.video-actions button.danger {
  color: #b91c1c;
  background: #fee2e2;
}

.preview-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.66);
}

.preview-panel {
  width: 100%;
  padding: 24rpx;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
}

.preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.preview-head text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-head button {
  width: 100rpx;
  height: 56rpx;
  color: #334155;
  background: #f1f5f9;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.preview-video {
  width: 100%;
  height: 760rpx;
  background: #0f172a;
  border-radius: 18rpx;
}
