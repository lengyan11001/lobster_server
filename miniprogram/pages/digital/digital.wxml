<view class="page digital-page">
  <view class="digital-stars stars-a"></view>
  <view class="digital-stars stars-b"></view>

  <view wx:if="{{authPanelVisible && !phoneBound}}" class="auth-card">
    <text class="auth-title">授权后继续</text>
    <text class="auth-text">{{authHint}}</text>
    <view class="auth-actions">
      <button class="ghost-btn" bindtap="login">微信登录</button>
      <button class="primary-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">授权手机号</button>
    </view>
  </view>

  <view wx:if="{{!phoneBound && !authPanelVisible}}" class="auth-card">
    <text class="auth-title">先登录账号</text>
    <text class="auth-text">数字人生成会关联你的账号余额和作品记录。</text>
    <button class="primary-btn auth-login" bindtap="login">微信登录</button>
  </view>

  <block wx:else>
    <block wx:if="{{pageMode === 'select'}}">
      <view class="digital-top">
        <button class="back-btn" bindtap="goBack">‹</button>
        <text class="digital-title">选择数字分身</text>
        <button class="more-btn" bindtap="goManage">管理</button>
      </view>

      <view class="hero-preview">
        <image wx:if="{{selectedAvatar && selectedAvatar.image_url}}" class="hero-avatar" src="{{selectedAvatar.image_url}}" mode="aspectFill" />
        <view wx:else class="hero-avatar hero-placeholder">数</view>
        <view class="hero-shadow"></view>
        <text class="hero-name">{{selectedAvatar ? selectedAvatar.title : '请选择数字人'}}</text>
      </view>

      <view class="asset-switch">
        <button class="{{activeAssetTab === 'avatar' ? 'active' : ''}}" data-tab="avatar" bindtap="setAssetTab">我的形象</button>
        <button class="{{activeAssetTab === 'voice' ? 'active' : ''}}" data-tab="voice" bindtap="setAssetTab">我的声音</button>
        <button class="manage-chip" bindtap="goManage">管理</button>
      </view>

      <block wx:if="{{activeAssetTab === 'avatar'}}">
        <scroll-view scroll-x class="select-strip-scroll" show-scrollbar="{{false}}">
          <view class="select-strip">
            <view class="create-mini-card">
              <view class="plus-circle">+</view>
              <text>克隆分身</text>
            </view>
            <view wx:for="{{displayAvatars}}" wx:key="id" class="mini-avatar-card {{selectedAvatar && selectedAvatar.avatar === item.avatar ? 'selected' : ''}}" data-source="{{displayAvatarSource}}" data-index="{{index}}" bindtap="selectAvatar">
              <image wx:if="{{item.image_url}}" class="mini-avatar-img" src="{{item.image_url}}" mode="aspectFill" />
              <view wx:else class="mini-avatar-img mini-placeholder">数</view>
              <text>{{item.title}}</text>
            </view>
          </view>
        </scroll-view>
      </block>

      <block wx:else>
        <scroll-view scroll-x class="select-strip-scroll" show-scrollbar="{{false}}">
          <view class="select-strip">
            <view class="create-mini-card voice-create">
              <view class="plus-circle">麦</view>
              <text>模拟声音</text>
            </view>
            <view wx:for="{{displayVoices}}" wx:key="id" class="mini-voice-card {{selectedVoice && selectedVoice.voice === item.voice ? 'selected' : ''}}" data-source="{{displayVoiceSource}}" data-index="{{index}}" bindtap="selectVoice">
              <button class="play-round" catchtap="playVoice" data-source="{{displayVoiceSource}}" data-index="{{index}}">{{audioPlayingId === item.id ? 'Ⅱ' : '▶'}}</button>
              <text class="mini-voice-title">{{item.title}}</text>
              <text class="mini-voice-time">30秒</text>
            </view>
          </view>
        </scroll-view>
      </block>

      <button class="bottom-create-btn" bindtap="goCreate">去创作</button>
    </block>

    <block wx:elif="{{pageMode === 'manage'}}">
      <view class="manage-top">
        <button class="back-btn" bindtap="goSelect">‹</button>
        <view>
          <text class="manage-title">管理数字分身</text>
          <text class="manage-sub">MANAGE AVATARS</text>
        </view>
      </view>

      <view class="manage-tabs">
        <button class="{{manageTab === 'avatar' ? 'active avatar-active' : ''}}" data-tab="avatar" bindtap="setManageTab">形象管理</button>
        <button class="{{manageTab === 'voice' ? 'active voice-active' : ''}}" data-tab="voice" bindtap="setManageTab">声音管理</button>
      </view>

      <block wx:if="{{manageTab === 'avatar'}}">
        <view class="manage-head">
          <text>我的形象</text>
          <text>{{avatarsMine.length || avatarsPublic.length}}个</text>
        </view>
        <view wx:if="{{loadingAssets}}" class="empty">正在加载数字人...</view>
        <view wx:else class="avatar-manage-grid">
          <view wx:for="{{displayAvatars}}" wx:key="id" class="manage-avatar-card" data-source="{{displayAvatarSource}}" data-index="{{index}}" bindtap="selectAvatar">
            <image wx:if="{{item.image_url}}" class="manage-avatar-img" src="{{item.image_url}}" mode="aspectFill" />
            <view wx:else class="manage-avatar-img manage-placeholder">数</view>
            <text>{{item.title}}</text>
          </view>
        </view>
      </block>

      <block wx:else>
        <view class="manage-head">
          <text>我的声音</text>
          <text>{{voicesMine.length || voicesPublic.length}}个</text>
        </view>
        <view wx:if="{{loadingAssets}}" class="empty">正在加载声音...</view>
        <view wx:else class="voice-manage-grid">
          <view wx:for="{{displayVoices}}" wx:key="id" class="manage-voice-card" data-source="{{displayVoiceSource}}" data-index="{{index}}" bindtap="selectVoice">
            <button class="manage-play" catchtap="playVoice" data-source="{{displayVoiceSource}}" data-index="{{index}}">{{audioPlayingId === item.id ? 'Ⅱ' : '▶'}}</button>
            <text>{{item.title}}</text>
            <text>30秒</text>
          </view>
        </view>
      </block>
    </block>

    <block wx:elif="{{pageMode === 'create'}}">
      <view class="create-top">
        <button class="back-btn" bindtap="goSelect">‹</button>
        <text class="step-title"><text>1.</text> 输入文字</text>
      </view>

      <view class="create-form">
        <text class="form-label">标题（选填）</text>
        <input class="form-input" value="{{title}}" bindinput="onTitleInput" maxlength="50" placeholder="可不填" placeholder-class="form-placeholder" />

        <text class="form-label">话题（选填）</text>
        <input class="form-input" placeholder="可不填" placeholder-class="form-placeholder" />

        <view class="script-head">
          <text class="form-label">请输入视频内容</text>
          <button class="sample-btn" bindtap="fillSample">示例文案</button>
        </view>
        <textarea class="script-input" value="{{text}}" bindinput="onTextInput" maxlength="1500" placeholder="请输入视频内容" placeholder-class="form-placeholder" />

        <view class="create-actions">
          <button class="assist-btn" bindtap="fillSample">AI帮我写</button>
          <view class="subtitle-toggle">
            <text>字幕</text>
            <switch checked="{{stShow}}" bindchange="toggleSubtitle" />
          </view>
        </view>
      </view>

      <button class="next-btn" bindtap="goPickDigital">下一步</button>

      <view wx:if="{{pollingTaskId}}" class="progress-card">
        <view class="spinner"></view>
        <text>{{progressText || '视频生成中'}}</text>
      </view>
    </block>

    <block wx:else>
      <view class="create-top pick-top">
        <button class="back-btn" bindtap="goCreate">‹</button>
        <text class="step-title"><text>2.</text> 选择数字人</text>
      </view>

      <view class="pick-section">
        <view class="pick-head">
          <text>选择数字人</text>
          <button bindtap="goManage">更多 ›</button>
        </view>
        <scroll-view scroll-x class="pick-scroll" show-scrollbar="{{false}}">
          <view class="pick-strip">
            <view class="custom-card">
              <view class="custom-plus">+</view>
              <text>自定义</text>
            </view>
            <view wx:for="{{displayAvatars}}" wx:key="id" class="pick-avatar-card {{selectedAvatar && selectedAvatar.avatar === item.avatar ? 'selected' : ''}}" data-source="{{displayAvatarSource}}" data-index="{{index}}" bindtap="selectAvatar">
              <image wx:if="{{item.image_url}}" class="pick-avatar-img" src="{{item.image_url}}" mode="aspectFill" />
              <view wx:else class="pick-avatar-img pick-placeholder">数</view>
              <view wx:if="{{selectedAvatar && selectedAvatar.avatar === item.avatar}}" class="selected-check">✓</view>
              <text>{{item.title}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="pick-section">
        <view class="pick-head">
          <text>选择声音</text>
          <button bindtap="goManage">更多 ›</button>
        </view>
        <view class="speed-row">
          <text>语速</text>
          <text>{{speechRateText}}</text>
        </view>
        <slider class="speed-slider" min="50" max="200" step="5" value="{{speechRate * 100}}" block-size="26" activeColor="#10f5dd" backgroundColor="rgba(255,255,255,0.16)" block-color="#ffffff" bindchanging="onSpeechRateChange" bindchange="onSpeechRateChange" />
        <scroll-view scroll-x class="pick-scroll" show-scrollbar="{{false}}">
          <view class="pick-strip">
            <view class="custom-card voice-custom">
              <view class="custom-plus">+</view>
              <text>自定义</text>
            </view>
            <view wx:for="{{displayVoices}}" wx:key="id" class="pick-voice-card {{selectedVoice && selectedVoice.voice === item.voice ? 'selected' : ''}}" data-source="{{displayVoiceSource}}" data-index="{{index}}" bindtap="selectVoice">
              <button class="pick-play" catchtap="playVoice" data-source="{{displayVoiceSource}}" data-index="{{index}}">{{audioPlayingId === item.id ? 'Ⅱ' : '▶'}}</button>
              <view wx:if="{{selectedVoice && selectedVoice.voice === item.voice}}" class="selected-check">✓</view>
              <text>{{item.title}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view wx:if="{{pollingTaskId}}" class="progress-card">
        <view class="spinner"></view>
        <text>{{progressText || '视频生成中'}}</text>
      </view>

      <button class="next-btn generate-btn" loading="{{submitting}}" bindtap="submitDigitalTask">提交数字人任务</button>
    </block>
  </block>

  <view wx:if="{{previewVisible}}" class="preview-mask">
    <view class="preview-panel">
      <view class="preview-head">
        <text>{{selectedVideo.title || '数字人视频'}}</text>
        <button bindtap="closePreview">关闭</button>
      </view>
      <video src="{{previewVideoUrl}}" controls autoplay class="preview-video"></video>
      <view class="auth-actions">
        <button class="ghost-btn" bindtap="copyVideo">复制链接</button>
        <button class="primary-btn" bindtap="saveVideo">保存视频</button>
      </view>
    </view>
  </view>
</view>
