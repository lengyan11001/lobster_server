.chat-page {
  min-height: 100vh;
  padding-bottom: 360rpx;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #07101f, #1d4ed8 62%, #06b6d4);
  border-radius: 28rpx;
}

.chat-title,
.chat-subtitle {
  display: block;
}

.chat-title {
  font-size: 38rpx;
  font-weight: 900;
}

.chat-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
}

.mini-btn {
  flex: 0 0 132rpx;
  height: 68rpx;
  color: #0f172a;
  background: #fff;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.quick-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 22rpx 0;
}

.quick-row button {
  height: 70rpx;
  color: #1d4ed8;
  background: #eff6ff;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.auth-section {
  margin-top: 18rpx;
}

.sms-link {
  margin-top: 16rpx;
  padding: 0;
  color: #1d4ed8;
  text-align: left;
  background: transparent;
  font-size: 24rpx;
  font-weight: 800;
}

.sms-bind-box {
  display: grid;
  gap: 12rpx;
  margin-top: 16rpx;
}

.sms-code-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 136rpx;
  gap: 12rpx;
}

.sms-code-btn,
.sms-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  text-align: center;
}

.sms-code-btn[disabled] {
  color: #64748b;
  background: #e2e8f0;
}

.message-list {
  margin-top: 18rpx;
}

.message-card {
  margin-top: 22rpx;
}

.message-bottom {
  height: 1px;
}

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  font-size: 27rpx;
  line-height: 1.6;
}

.user-bubble {
  margin-left: 80rpx;
  color: #fff;
  background: #2563eb;
  border-bottom-right-radius: 8rpx;
}

.reply-bubble {
  margin-top: 12rpx;
  margin-right: 48rpx;
  color: #0f172a;
  background: #fff;
  border: 1rpx solid #e5eaf3;
  border-bottom-left-radius: 8rpx;
}

.media-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 14rpx;
}

.media-card {
  padding: 14rpx;
  background: #fff;
  border: 1rpx solid #e5eaf3;
  border-radius: 20rpx;
}

.preview {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  background: #0f172a;
  border-radius: 16rpx;
}

.image-preview {
  background: #eef2f7;
}

.video-preview {
  display: block;
}

.file-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220rpx;
  color: #64748b;
  background: #f8fafc;
  border-radius: 16rpx;
}

.media-title {
  display: block;
  overflow: hidden;
  margin-top: 12rpx;
  color: #334155;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.media-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 12rpx;
}

.media-actions .primary-btn,
.media-actions .ghost-btn {
  min-height: 60rpx;
  padding: 0 12rpx;
  font-size: 23rpx;
}

.composer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(243, 246, 251, 0.96);
  border-top: 1rpx solid #dbe3ef;
}

.message-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 86rpx;
  max-height: 210rpx;
  padding: 22rpx 24rpx;
  color: #0f172a;
  background: #fff;
  border: 1rpx solid #dbe3ef;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.45;
}

.send-btn {
  width: 100%;
  margin-top: 14rpx;
}
