.compact {
  padding: 30rpx;
}

.compact .hero-title {
  font-size: 40rpx;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 24rpx 0;
  padding: 8rpx;
  background: #e9eef7;
  border-radius: 999rpx;
}

.tabs button {
  height: 68rpx;
  color: #64748b;
  background: transparent;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.tabs button.active {
  color: #0f172a;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.08);
}

.media-card {
  margin-top: 22rpx;
  padding: 22rpx;
  background: #fff;
  border: 1rpx solid #e5eaf3;
  border-radius: 24rpx;
}

.media-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.media-title {
  overflow: hidden;
  color: #0f172a;
  font-size: 29rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.media-kind {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #2563eb;
  background: #eff6ff;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.preview {
  width: 100%;
  height: 420rpx;
  overflow: hidden;
  background: #0f172a;
  border-radius: 18rpx;
}

.image-preview {
  background: #eef2f7;
}

.video-preview {
  display: block;
}

.file-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 240rpx;
  color: #64748b;
  background: #f8fafc;
  border-radius: 18rpx;
}

.media-meta {
  display: block;
  margin-top: 14rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.55;
}

.media-actions {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

