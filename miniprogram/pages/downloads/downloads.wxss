page {
  background: #020403;
}

.works-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 36rpx 24rpx 150rpx;
  color: #f8fafc;
  background:
    radial-gradient(circle at 52% 26%, rgba(148, 163, 184, 0.3) 0, rgba(30, 64, 175, 0.16) 24%, transparent 48%),
    radial-gradient(circle at 48% 72%, rgba(16, 245, 221, 0.15) 0, transparent 34%),
    linear-gradient(180deg, #050914 0%, #020403 100%);
}

.space-layer {
  position: absolute;
  pointer-events: none;
}

.stars-a {
  left: 0;
  right: 0;
  top: 0;
  height: 100%;
  background-image: radial-gradient(circle, rgba(255,255,255,0.75) 0 2rpx, transparent 3rpx);
  background-size: 112rpx 148rpx;
  opacity: 0.32;
}

.stars-b {
  left: -20%;
  right: -20%;
  top: 160rpx;
  height: 1100rpx;
  background-image: radial-gradient(circle, rgba(34,211,238,0.7) 0 2rpx, transparent 4rpx);
  background-size: 230rpx 210rpx;
  opacity: 0.14;
}

.works-head,
.media-tabs,
.kind-tabs,
.auth-card,
.empty-card,
.work-list {
  position: relative;
  z-index: 1;
}

.works-head {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 108rpx;
}

.works-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.refresh-btn {
  position: absolute;
  right: 0;
  top: 24rpx;
  width: 104rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  color: rgba(255,255,255,0.82);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.media-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  padding: 12rpx;
  background: rgba(28, 31, 43, 0.92);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 32rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.1);
}

.media-tabs button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 126rpx;
  margin: 0;
  padding: 0;
  color: rgba(255,255,255,0.72);
  background: transparent;
  border-radius: 24rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.media-tabs button.active {
  color: #10f5dd;
  background: linear-gradient(135deg, rgba(16, 245, 221, 0.25), rgba(8, 107, 130, 0.6));
  border: 1rpx solid rgba(16, 245, 221, 0.58);
}

.tab-icon {
  margin-bottom: 10rpx;
  font-size: 32rpx;
}

.kind-tabs {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
}

.kind-tabs button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 150rpx;
  height: 70rpx;
  margin: 0;
  padding: 0 28rpx;
  color: rgba(255,255,255,0.78);
  background: rgba(59, 66, 87, 0.88);
  border: 1rpx solid rgba(255,255,255,0.16);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.kind-tabs button.active {
  color: #10f5dd;
  background: rgba(16, 245, 221, 0.18);
  border-color: rgba(16, 245, 221, 0.72);
  box-shadow: 0 0 24rpx rgba(16, 245, 221, 0.12);
}

.auth-card,
.empty-card {
  margin-top: 44rpx;
  padding: 34rpx;
  background: rgba(15, 18, 28, 0.86);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 28rpx;
}

.auth-title,
.auth-text,
.empty-card text {
  display: block;
}

.auth-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
}

.auth-text,
.empty-card text {
  margin-top: 12rpx;
  color: rgba(226, 232, 240, 0.62);
  font-size: 25rpx;
  line-height: 1.55;
}

.auth-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.primary-btn,
.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.primary-btn {
  margin-top: 24rpx;
  color: #061312;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
}

.ghost-btn {
  color: rgba(255,255,255,0.84);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.work-list {
  display: grid;
  gap: 24rpx;
  margin-top: 52rpx;
}

.media-grid-list {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
  margin-top: 44rpx;
}

.media-work-card {
  overflow: hidden;
  background: rgba(15, 18, 28, 0.9);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 28rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.08);
}

.media-work-img {
  display: block;
  width: 100%;
  height: 310rpx;
  background: rgba(255,255,255,0.08);
}

.media-work-video {
  display: block;
}

.media-work-file {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(226, 232, 240, 0.72);
  font-size: 24rpx;
  font-weight: 900;
}

.media-work-body {
  padding: 18rpx;
}

.media-work-title,
.media-work-time {
  display: block;
}

.media-work-title {
  overflow: hidden;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.media-work-time {
  margin-top: 8rpx;
  color: rgba(226, 232, 240, 0.58);
  font-size: 21rpx;
}

.media-work-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 18rpx;
}

.media-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  margin: 0;
  padding: 0;
  color: #10f5dd;
  background: rgba(255,255,255,0.09);
  border: 1rpx solid rgba(255,255,255,0.13);
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.media-action-btn.primary {
  color: #061312;
  background: linear-gradient(135deg, #10f5dd, #67e8f9);
  border-color: rgba(103,232,249,0.72);
}

.work-card {
  position: relative;
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr) 58rpx;
  gap: 22rpx;
  min-height: 300rpx;
  padding: 24rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 38% 92%, rgba(244, 114, 182, 0.22) 0, transparent 42%),
    linear-gradient(135deg, rgba(39, 45, 70, 0.94), rgba(20, 20, 29, 0.92));
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 30rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.1);
}

.work-cover {
  position: relative;
  height: 254rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.08);
  border-radius: 20rpx;
}

.cover-img,
.cover-video,
.cover-placeholder {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #10f5dd;
  background: linear-gradient(135deg, #111827, #0f766e);
  font-size: 46rpx;
  font-weight: 900;
}

.cover-state {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: rgba(0, 0, 0, 0.28);
  font-weight: 900;
}

.cover-state text:first-child {
  font-size: 31rpx;
}

.cover-state text:last-child {
  margin-top: 10rpx;
  color: #10f5dd;
  font-size: 22rpx;
}

.play-btn {
  position: absolute;
  left: 50%;
  top: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  color: #1688ff;
  background: #fff;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  font-weight: 900;
}

.work-main {
  min-width: 0;
  padding: 10rpx 0;
}

.work-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.type-chip,
.status-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 54rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.type-chip {
  color: #10f5dd;
  background: rgba(16, 245, 221, 0.16);
  border: 1rpx solid rgba(16, 245, 221, 0.62);
}

.status-chip {
  color: #10f5dd;
  background: rgba(16, 245, 221, 0.13);
  border: 1rpx solid rgba(16, 245, 221, 0.42);
}

.status-chip.success {
  color: #34d399;
  background: rgba(34, 197, 94, 0.14);
  border-color: rgba(34, 197, 94, 0.5);
}

.status-chip.failed {
  color: #fb7185;
  background: rgba(244, 63, 94, 0.14);
  border-color: rgba(244, 63, 94, 0.5);
}

.work-title,
.work-prompt,
.work-time {
  display: block;
}

.work-title {
  overflow: hidden;
  margin-top: 24rpx;
  color: #fff;
  font-size: 29rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-prompt {
  display: -webkit-box;
  overflow: hidden;
  min-height: 72rpx;
  margin-top: 14rpx;
  color: rgba(226, 232, 240, 0.62);
  font-size: 24rpx;
  line-height: 1.48;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.work-time {
  margin-top: 46rpx;
  color: rgba(226, 232, 240, 0.62);
  font-size: 23rpx;
}

.work-actions {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  padding: 88rpx 0 10rpx;
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin: 0;
  padding: 0;
  color: #10f5dd;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.18);
  border-radius: 999rpx;
  font-size: 22rpx;
}

.icon-btn.danger {
  color: #fff;
}
