<view class="page">
  <view class="hero compact">
    <text class="hero-title">素材下载</text>
    <text class="hero-subtitle">预览 online 生成结果，一键保存图片或视频到手机相册。</text>
  </view>

  <view class="tabs">
    <button class="{{mediaType === 'media' ? 'active' : ''}}" data-type="media" bindtap="switchType">全部</button>
    <button class="{{mediaType === 'video' ? 'active' : ''}}" data-type="video" bindtap="switchType">视频</button>
    <button class="{{mediaType === 'image' ? 'active' : ''}}" data-type="image" bindtap="switchType">图片</button>
    <button class="{{mediaType === 'audio' ? 'active' : ''}}" data-type="audio" bindtap="switchType">音频</button>
  </view>

  <view wx:if="{{!phoneBound}}" class="section">
    <text class="section-title">需要先绑定</text>
    <text class="muted">请回到首页，微信登录并授权手机号后再查看素材。</text>
    <view class="button-row">
      <button class="primary-btn" bindtap="goHome">去绑定</button>
    </view>
  </view>

  <view wx:elif="{{loading}}" class="empty">正在加载素材...</view>
  <view wx:elif="{{items.length === 0}}" class="empty">还没有可下载素材</view>

  <block wx:else>
    <view wx:for="{{items}}" wx:key="id" class="media-card">
      <view class="media-head">
        <text class="media-title">{{item.title || item.asset_id || '生成素材'}}</text>
        <text class="media-kind">{{item.media_type}}</text>
      </view>
      <image wx:if="{{item.media_type === 'image'}}" class="preview image-preview" src="{{item.preview_url || item.url}}" mode="aspectFill" data-url="{{item.preview_url || item.url}}" bindtap="previewImage" />
      <video wx:elif="{{item.media_type === 'video'}}" class="preview video-preview" src="{{item.preview_url || item.url}}" controls show-fullscreen-btn show-play-btn></video>
      <view wx:else class="file-preview">
        <text>{{item.media_type || 'media'}}</text>
      </view>
      <text wx:if="{{item.prompt}}" class="media-meta">{{item.prompt}}</text>
      <view class="media-actions">
        <button class="ghost-btn" data-index="{{index}}" bindtap="copyLink">复制链接</button>
        <button class="primary-btn" data-index="{{index}}" bindtap="saveMedia">{{item.media_type === 'image' || item.media_type === 'video' ? '保存到相册' : '复制下载链接'}}</button>
      </view>
    </view>
  </block>
</view>

