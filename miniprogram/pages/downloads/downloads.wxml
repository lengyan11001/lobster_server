<view class="works-page">
  <view class="space-layer stars-a"></view>
  <view class="space-layer stars-b"></view>

  <view class="works-head">
    <text class="works-title">我的作品</text>
    <button class="refresh-btn" loading="{{loading}}" bindtap="loadWorks">刷新</button>
  </view>

  <view class="media-tabs">
    <button class="{{mediaTab === 'video' ? 'active' : ''}}" data-tab="video" bindtap="setMediaTab">
      <view class="tab-icon tab-video"></view>
      <text>视频</text>
    </button>
    <button class="{{mediaTab === 'image' ? 'active' : ''}}" data-tab="image" bindtap="setMediaTab">
      <view class="tab-icon tab-image"></view>
      <text>图片</text>
    </button>
    <button class="{{mediaTab === 'text' ? 'active' : ''}}" data-tab="text" bindtap="setMediaTab">
      <view class="tab-icon tab-text"></view>
      <text>文本</text>
    </button>
    <button class="{{mediaTab === 'audio' ? 'active' : ''}}" data-tab="audio" bindtap="setMediaTab">
      <view class="tab-icon tab-audio"></view>
      <text>音频</text>
    </button>
  </view>

  <view wx:if="{{mediaTab === 'video'}}" class="kind-tabs">
    <button class="{{videoKind === 'digital' ? 'active' : ''}}" data-kind="digital" bindtap="setVideoKind">数字人视频</button>
    <button class="{{videoKind === 'super' ? 'active' : ''}}" data-kind="super" bindtap="setVideoKind">超级视频</button>
  </view>

  <block wx:if="{{authPanelVisible && !phoneBound}}">
    <view class="auth-card">
      <text class="auth-title">授权后查看作品</text>
      <text class="auth-text">{{authHint}}</text>
      <view class="auth-actions">
        <button class="ghost-btn" bindtap="login">快捷登录</button>
        <button class="primary-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">手机号快捷登录</button>
      </view>
    </view>
  </block>

  <block wx:elif="{{!phoneBound && !authPanelVisible}}">
    <view class="empty-card">
      <text>登录后查看生成作品</text>
      <button class="primary-btn" bindtap="login">快捷登录</button>
    </view>
  </block>

  <block wx:elif="{{mediaTab === 'text' || mediaTab === 'audio'}}">
    <view class="empty-card">
      <text>这里暂时还没有作品</text>
    </view>
  </block>

  <block wx:elif="{{((mediaTab === 'image') || (mediaTab === 'video' && videoKind === 'super')) && loading && mediaWorks.length === 0}}">
    <view class="empty-card">
      <text>{{mediaTab === 'image' ? '正在加载图片作品...' : '正在加载视频作品...'}}</text>
    </view>
  </block>

  <block wx:elif="{{((mediaTab === 'image') || (mediaTab === 'video' && videoKind === 'super')) && mediaWorks.length === 0}}">
    <view class="empty-card">
      <text>{{mediaTab === 'image' ? '这里暂时还没有图片作品' : '这里暂时还没有超级视频'}}</text>
    </view>
  </block>

  <block wx:elif="{{mediaTab === 'image' || (mediaTab === 'video' && videoKind === 'super')}}">
    <view wx:if="{{mediaTab === 'video' && videoKind === 'super'}}" class="work-list">
      <view wx:for="{{mediaWorks}}" wx:key="id" wx:for-index="index" class="work-card media-list-card" data-index="{{index}}" bindtap="openMediaWork">
        <view class="work-cover">
          <image wx:if="{{item.cover_url}}" class="cover-img" src="{{item.cover_url}}" mode="aspectFill" />
          <video wx:elif="{{item.is_success && item.playable_url}}" class="cover-video" src="{{item.playable_url}}" show-center-play-btn="{{false}}" show-play-btn="{{false}}" controls="{{false}}" muted object-fit="cover"></video>
          <view wx:else class="cover-placeholder">{{item.work_type_label || 'AI'}}</view>
          <view wx:if="{{item.is_processing}}" class="cover-state">
            <text>生成中</text>
            <text>预计5-10分钟</text>
          </view>
          <view wx:if="{{item.is_failed}}" class="cover-state failed">
            <text>生成失败</text>
            <text>{{item.error_message || '请重新提交任务'}}</text>
          </view>
          <view wx:if="{{item.is_success}}" class="play-btn">▶</view>
        </view>

        <view class="work-main">
          <view class="work-line">
            <text class="type-chip">{{item.work_type_label}}</text>
            <text class="status-chip {{item.status}}">{{item.status_label}}</text>
          </view>
          <text class="work-title">{{item.title}}</text>
          <text class="work-prompt">{{item.prompt || 'AI视频生成任务'}}</text>
        </view>
        <view class="card-meta-row">
          <text>任务时间：{{item.created_at_text || '--'}}</text>
          <text wx:if="{{item.is_success}}">视频结果：可播放</text>
          <text wx:elif="{{item.is_processing}}">视频结果：生成中</text>
          <text wx:elif="{{item.is_failed}}">视频结果：失败</text>
        </view>
        <view wx:if="{{item.publish_draft}}" class="publish-row" catchtap="noop">
          <text>{{item.publish_status_label}} · {{item.publish_target_label}}</text>
          <button wx:if="{{item.can_publish}}" data-index="{{index}}" catchtap="publishMediaWork">{{item.publish_status === 'failed' ? '重新发布' : '发布'}}</button>
        </view>
      </view>
    </view>

    <view wx:else class="media-grid-list">
      <view wx:for="{{mediaWorks}}" wx:key="id" wx:for-index="index" class="media-work-card" data-index="{{index}}" bindtap="openMediaWork">
        <image wx:if="{{item.media_type === 'image' && (item.preview_url || item.url)}}" class="media-work-img" src="{{item.preview_url || item.url}}" mode="aspectFill" />
        <view wx:elif="{{item.media_type === 'image' && item.is_processing}}" class="media-work-img media-work-file">生成中</view>
        <view wx:elif="{{item.media_type === 'image' && item.is_failed}}" class="media-work-img media-work-file">失败</view>
        <view wx:else class="media-work-img media-work-file">{{item.media_type}}</view>
        <view class="media-work-body">
          <view class="media-work-line">
            <text class="type-chip media-chip">{{item.work_type_label}}</text>
            <text class="status-chip media-chip {{item.status}}">{{item.status_label}}</text>
          </view>
          <text class="media-work-title">{{item.title}}</text>
          <text class="media-work-time">{{item.created_at_text || '--'}}</text>
        </view>
        <view wx:if="{{item.publish_draft}}" class="publish-row compact" catchtap="noop">
          <text>{{item.publish_status_label}} · {{item.publish_target_label}}</text>
          <button wx:if="{{item.can_publish}}" data-index="{{index}}" catchtap="publishMediaWork">{{item.publish_status === 'failed' ? '重新发布' : '发布'}}</button>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{mediaTab !== 'video' || videoKind !== 'digital'}}">
    <view class="empty-card">
      <text>这里暂时还没有作品</text>
    </view>
  </block>

  <block wx:elif="{{loading && works.length === 0}}">
    <view class="empty-card">
      <text>正在加载作品...</text>
    </view>
  </block>

  <block wx:elif="{{works.length === 0}}">
    <view class="empty-card">
      <text>还没有数字人视频</text>
      <button class="primary-btn" bindtap="goCreate">去创作</button>
    </view>
  </block>

  <block wx:else>
    <view class="work-list">
      <view wx:for="{{works}}" wx:key="id" wx:for-index="index" class="work-card media-list-card" data-index="{{index}}" bindtap="openWork">
        <view class="work-cover">
          <image wx:if="{{item.cover_url}}" class="cover-img" src="{{item.cover_url}}" mode="aspectFill" />
          <video wx:elif="{{item.is_success && item.playable_url}}" class="cover-video" src="{{item.playable_url}}" show-center-play-btn="{{false}}" show-play-btn="{{false}}" controls="{{false}}" muted object-fit="cover"></video>
          <view wx:else class="cover-placeholder">{{item.work_type_label || 'AI'}}</view>
          <view wx:if="{{item.is_processing}}" class="cover-state">
            <text>生成中</text>
            <text>预计5-10分钟</text>
          </view>
          <view wx:if="{{item.is_success}}" class="play-btn">▶</view>
        </view>

        <view class="work-main">
          <view class="work-line">
            <text class="type-chip">{{item.work_type_label}}</text>
            <text class="status-chip {{item.status}}">{{item.status_label}}</text>
          </view>
          <text class="work-title">{{item.title}}</text>
          <text class="work-prompt">{{item.prompt || item.message || '暂无创作参数'}}</text>
        </view>
        <view class="card-meta-row">
          <text>任务时间：{{item.created_at_text || '--'}}</text>
          <text wx:if="{{item.is_success}}">视频结果：可播放</text>
          <text wx:elif="{{item.is_processing}}">视频结果：生成中</text>
          <text wx:elif="{{item.is_failed}}">视频结果：失败</text>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{previewVisible}}" class="video-modal" catchtap="closePreview">
    <view class="video-modal-panel" catchtap="noop">
      <view class="modal-head">
        <view class="modal-title-wrap">
          <text class="modal-title">{{previewItem.title || 'AI视频作品'}}</text>
          <text class="modal-sub">{{previewItem.work_type_label || 'AI视频'}} · {{previewItem.status_label || '已完成'}}</text>
        </view>
        <button class="modal-close" bindtap="closePreview">×</button>
      </view>
      <video
        class="modal-video"
        src="{{previewVideoUrl}}"
        controls
        autoplay
        show-fullscreen-btn
        show-play-btn
        object-fit="contain"
      ></video>
      <view class="modal-actions">
        <button class="modal-btn primary" bindtap="savePreviewWork">保存</button>
        <button class="modal-btn" open-type="share">分享</button>
      </view>
    </view>
  </view>
</view>
