<view class="works-page">
  <view class="space-layer stars-a"></view>
  <view class="space-layer stars-b"></view>

  <view class="works-head">
    <text class="works-title">我的作品</text>
    <button class="refresh-btn" loading="{{loading}}" bindtap="loadWorks">刷新</button>
  </view>

  <view class="media-tabs">
    <button class="{{mediaTab === 'video' ? 'active' : ''}}" data-tab="video" bindtap="setMediaTab">
      <text class="tab-icon">▣</text>
      <text>视频</text>
    </button>
    <button class="{{mediaTab === 'image' ? 'active' : ''}}" data-tab="image" bindtap="setMediaTab">
      <text class="tab-icon">▧</text>
      <text>图片</text>
    </button>
    <button class="{{mediaTab === 'text' ? 'active' : ''}}" data-tab="text" bindtap="setMediaTab">
      <text class="tab-icon">▤</text>
      <text>文本</text>
    </button>
    <button class="{{mediaTab === 'audio' ? 'active' : ''}}" data-tab="audio" bindtap="setMediaTab">
      <text class="tab-icon">♪</text>
      <text>音频</text>
    </button>
  </view>

  <view wx:if="{{mediaTab === 'video'}}" class="kind-tabs">
    <button class="{{videoKind === 'digital' ? 'active' : ''}}" data-kind="digital" bindtap="setVideoKind">数字人视频</button>
    <button class="{{videoKind === 'super' ? 'active' : ''}}" data-kind="super" bindtap="setVideoKind">超级视频</button>
  </view>

  <block wx:if="{{authPanelVisible && !phoneBound}}">
    <view class="auth-card">
      <text class="auth-title">授权后查看作品</text>
      <text class="auth-text">{{authHint}}</text>
      <view class="auth-actions">
        <button class="ghost-btn" bindtap="login">微信登录</button>
        <button class="primary-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">授权手机号</button>
      </view>
    </view>
  </block>

  <block wx:elif="{{!phoneBound && !authPanelVisible}}">
    <view class="empty-card">
      <text>登录后查看生成作品</text>
      <button class="primary-btn" bindtap="login">微信登录</button>
    </view>
  </block>

  <block wx:elif="{{mediaTab === 'text' || mediaTab === 'audio'}}">
    <view class="empty-card">
      <text>这里暂时还没有作品</text>
    </view>
  </block>

  <block wx:elif="{{((mediaTab === 'image') || (mediaTab === 'video' && videoKind === 'super')) && loading && mediaWorks.length === 0}}">
    <view class="empty-card">
      <text>{{mediaTab === 'image' ? '正在加载图片作品...' : '正在加载视频作品...'}}</text>
    </view>
  </block>

  <block wx:elif="{{((mediaTab === 'image') || (mediaTab === 'video' && videoKind === 'super')) && mediaWorks.length === 0}}">
    <view class="empty-card">
      <text>{{mediaTab === 'image' ? '这里暂时还没有图片作品' : '这里暂时还没有超级视频'}}</text>
    </view>
  </block>

  <block wx:elif="{{mediaTab === 'image' || (mediaTab === 'video' && videoKind === 'super')}}">
    <view class="media-grid-list">
      <view wx:for="{{mediaWorks}}" wx:key="id" wx:for-index="index" class="media-work-card">
        <image wx:if="{{item.media_type === 'image'}}" class="media-work-img" src="{{item.preview_url || item.url}}" mode="aspectFill" data-index="{{index}}" bindtap="previewMediaWork" />
        <video wx:elif="{{item.media_type === 'video'}}" class="media-work-img media-work-video" src="{{item.preview_url || item.url}}" controls show-fullscreen-btn show-play-btn object-fit="cover"></video>
        <view wx:else class="media-work-img media-work-file">{{item.media_type}}</view>
        <view class="media-work-body">
          <text class="media-work-title">{{item.title}}</text>
          <text class="media-work-time">{{item.created_at_text || '--'}}</text>
          <view class="media-work-actions">
            <button class="media-action-btn" data-index="{{index}}" bindtap="copyMediaWork">复制</button>
            <button class="media-action-btn primary" data-index="{{index}}" bindtap="saveMediaWork">保存</button>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{mediaTab !== 'video' || videoKind !== 'digital'}}">
    <view class="empty-card">
      <text>这里暂时还没有作品</text>
    </view>
  </block>

  <block wx:elif="{{loading && works.length === 0}}">
    <view class="empty-card">
      <text>正在加载作品...</text>
    </view>
  </block>

  <block wx:elif="{{works.length === 0}}">
    <view class="empty-card">
      <text>还没有数字人视频</text>
      <button class="primary-btn" bindtap="goCreate">去创作</button>
    </view>
  </block>

  <block wx:else>
    <view class="work-list">
      <view wx:for="{{works}}" wx:key="id" wx:for-index="index" class="work-card" data-index="{{index}}" bindtap="openWork">
        <view class="work-cover">
          <image wx:if="{{item.cover_url}}" class="cover-img" src="{{item.cover_url}}" mode="aspectFill" />
          <video wx:elif="{{item.is_success && item.playable_url}}" class="cover-video" src="{{item.playable_url}}" show-center-play-btn="{{false}}" controls="{{false}}" muted object-fit="cover"></video>
          <view wx:else class="cover-placeholder">AI</view>
          <view wx:if="{{item.is_processing}}" class="cover-state">
            <text>生成中</text>
            <text>预计5-10分钟</text>
          </view>
          <view wx:if="{{item.is_success}}" class="play-btn">▶</view>
        </view>

        <view class="work-main">
          <view class="work-line">
            <text class="type-chip">{{item.work_type_label}}</text>
            <text class="status-chip {{item.status}}">{{item.status_label}}</text>
          </view>
          <text class="work-title">{{item.title}}</text>
          <text class="work-prompt">{{item.prompt || item.message || '暂无创作参数'}}</text>
          <text class="work-time">时间: {{item.created_at_text || '--'}}</text>
        </view>

        <view class="work-actions" catchtap="noop">
          <button class="icon-btn" data-index="{{index}}" catchtap="copyPrompt">□</button>
          <button class="icon-btn danger" data-index="{{index}}" catchtap="deleteWork">⌫</button>
        </view>
      </view>
    </view>
  </block>
</view>
