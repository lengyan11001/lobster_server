<view class="page">
  <view class="profile-card">
    <view class="avatar">{{avatarText}}</view>
    <view class="profile-main">
      <text class="profile-name">{{phoneBound ? phone : (wechatLoggedIn ? '已微信登录' : '未绑定手机号')}}</text>
      <text class="profile-sub">{{phoneBound ? '已关联 online 账号' : (wechatLoggedIn ? '还需要授权手机号完成绑定' : '授权手机号后关联电脑端 online')}}</text>
    </view>
  </view>

  <view wx:if="{{!phoneBound}}" class="section bind-section">
    <text class="section-title">账号绑定</text>
    <text class="muted">绑定手机号后，手机端才能找到你的电脑端 online，并下发 AI 员工、数字人和素材任务。</text>
    <view wx:if="{{wechatLoggedIn}}" class="login-state">
      <view class="dot ok"></view>
      <text>微信登录已完成，请继续授权手机号。</text>
    </view>
    <view class="button-row">
      <button class="ghost-btn" loading="{{loginBusy}}" disabled="{{loginBusy}}" bindtap="login">{{wechatLoggedIn ? '重新登录' : '微信登录'}}</button>
      <button class="primary-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">授权手机号</button>
    </view>
    <view wx:if="{{loginDebug || lastError}}" class="debug-box">
      <text wx:if="{{loginDebug}}" class="debug-line">{{loginDebug}}</text>
      <text wx:if="{{lastError}}" class="debug-error">{{lastError}}</text>
      <button class="debug-copy" bindtap="copyDiagnostics">复制诊断信息</button>
    </view>
    <button class="sms-link" bindtap="showSmsBind">微信取号失败，用短信验证码绑定</button>
    <view wx:if="{{smsBindVisible}}" class="sms-bind-box">
      <input class="input" type="number" maxlength="11" value="{{smsPhone}}" bindinput="onSmsPhoneInput" placeholder="输入已开通 online 的手机号" />
      <view class="sms-code-row">
        <input class="input" type="number" maxlength="8" value="{{smsCode}}" bindinput="onSmsCodeInput" placeholder="短信验证码" />
        <button class="ghost-btn sms-code-btn" disabled="{{smsSending || smsCountdown > 0}}" loading="{{smsSending}}" bindtap="sendSmsCode">{{smsCountdown > 0 ? smsCountdown + 's' : '获取'}}</button>
      </view>
      <button class="primary-btn sms-submit" loading="{{smsBinding}}" bindtap="bindBySms">绑定手机号</button>
    </view>
  </view>

  <view class="section">
    <text class="section-title">设备</text>
    <view class="status-line">
      <view class="dot {{onlineAvailable ? 'ok' : 'warn'}}"></view>
      <text>{{onlineAvailable ? '检测到 online 设备' : '暂未检测到 online 设备'}}</text>
    </view>
    <view wx:for="{{onlineDevices}}" wx:key="installation_id" class="device-row">
      <view>
        <text class="device-name">{{item.display_name || item.installation_id}}</text>
        <text class="device-time">{{item.online ? '在线' : '离线'}} · {{item.last_seen_at}}</text>
      </view>
    </view>
    <view wx:if="{{onlineDevices.length === 0}}" class="muted empty-line">当前没有在线的电脑端 online。</view>
    <view class="button-row">
      <button class="ghost-btn" bindtap="loadDevices">刷新</button>
      <button class="primary-btn" bindtap="goDownloads">我的作品</button>
    </view>
  </view>

  <view class="section">
    <text class="section-title">任务结果</text>
    <view wx:if="{{runsLoading}}" class="muted empty-line">加载中...</view>
    <view wx:for="{{scheduledRuns}}" wx:key="id" class="device-row" data-id="{{item.id}}" bindtap="openScheduledRun">
      <view>
        <text class="device-name">{{item.title}}</text>
        <text class="device-time">{{item.status_text}} · {{item.time}}</text>
        <text wx:if="{{item.summary}}" class="device-time">{{item.summary}}</text>
      </view>
    </view>
    <view wx:if="{{!runsLoading && scheduledRuns.length === 0}}" class="muted empty-line">暂无定时任务结果。</view>
    <view class="button-row">
      <button class="ghost-btn" bindtap="loadScheduledRuns">刷新任务结果</button>
    </view>
  </view>

  <view class="section">
    <text class="section-title">当前手机</text>
    <text class="muted selectable">{{deviceId}}</text>
  </view>

  <view class="section">
    <button class="danger-btn" bindtap="logout">退出登录</button>
  </view>
</view>
