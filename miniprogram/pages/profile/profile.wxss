.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #111827, #1d4ed8);
  border-radius: 28rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.profile-main {
  min-width: 0;
}

.profile-name {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
}

.profile-sub {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
}

.bind-section .muted {
  display: block;
  margin-bottom: 4rpx;
}

.sms-link {
  margin-top: 16rpx;
  padding: 0;
  color: #1d4ed8;
  background: transparent;
  text-align: left;
  font-size: 25rpx;
  font-weight: 600;
}

.sms-bind-box {
  display: grid;
  gap: 12rpx;
  margin-top: 16rpx;
}

.sms-code-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 136rpx;
  gap: 12rpx;
}

.sms-code-btn,
.sms-submit {
  min-height: 76rpx;
  font-size: 25rpx;
}

.sms-code-btn[disabled] {
  color: #64748b;
  background: #e2e8f0;
}

.device-row {
  margin-top: 18rpx;
  padding: 18rpx;
  background: #f8fafc;
  border-radius: 18rpx;
}

.device-name,
.device-time {
  display: block;
}

.device-name {
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 700;
}

.device-time {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
}

.empty-line {
  display: block;
  margin-top: 18rpx;
}

.selectable {
  user-select: text;
}

