page {
  background: #020403;
}

.detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 30rpx 24rpx 154rpx;
  color: #f8fafc;
  background:
    radial-gradient(circle at 52% 24%, rgba(148, 163, 184, 0.24) 0, rgba(30, 64, 175, 0.14) 25%, transparent 50%),
    radial-gradient(circle at 50% 92%, rgba(16, 245, 221, 0.15) 0, transparent 32%),
    linear-gradient(180deg, #050914 0%, #020403 100%);
}

.space-layer {
  position: absolute;
  pointer-events: none;
}

.stars-a {
  left: 0;
  right: 0;
  top: 0;
  height: 100%;
  background-image: radial-gradient(circle, rgba(255,255,255,0.75) 0 2rpx, transparent 3rpx);
  background-size: 112rpx 148rpx;
  opacity: 0.3;
}

.stars-b {
  left: -20%;
  right: -20%;
  top: 160rpx;
  height: 1100rpx;
  background-image: radial-gradient(circle, rgba(34,211,238,0.68) 0 2rpx, transparent 4rpx);
  background-size: 230rpx 210rpx;
  opacity: 0.14;
}

.detail-head,
.player-panel,
.params-card,
.bottom-actions,
.empty-card {
  position: relative;
  z-index: 1;
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 116rpx;
}

.back-btn {
  position: absolute;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  margin: 0;
  padding: 0;
  color: #fff;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.18);
  border-radius: 999rpx;
  font-size: 48rpx;
  line-height: 1;
}

.detail-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.player-panel {
  overflow: hidden;
  background: #050505;
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 28rpx;
}

.work-video,
.video-waiting {
  width: 100%;
  height: 390rpx;
  background: #050505;
}

.video-waiting {
  position: relative;
  overflow: hidden;
}

.video-waiting image {
  width: 100%;
  height: 100%;
  opacity: 0.72;
}

.waiting-mask {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.34);
}

.waiting-mask text:first-child {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.waiting-mask text:last-child {
  margin-top: 12rpx;
  color: #10f5dd;
  font-size: 24rpx;
  font-weight: 900;
}

.params-card {
  margin-top: 34rpx;
  padding: 34rpx;
  background: rgba(4, 8, 12, 0.84);
  border: 1rpx solid rgba(255,255,255,0.13);
  border-radius: 30rpx;
  box-shadow: inset 0 1rpx rgba(255,255,255,0.08);
}

.card-title {
  display: block;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
}

.field-label {
  display: block;
  margin: 28rpx 0 12rpx;
  color: rgba(226, 232, 240, 0.76);
  font-size: 22rpx;
  font-weight: 900;
}

.field-box {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 22rpx;
  color: #fff;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.13);
  border-radius: 22rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.prompt-box {
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  min-height: 112rpx;
  padding-top: 22rpx;
  padding-bottom: 22rpx;
}

.prompt-box text {
  flex: 1;
  min-width: 0;
}

.scheduled-record-box {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  white-space: pre-wrap;
}

.moments-record-box {
  background: rgba(255, 253, 249, 0.12);
}

.moments-copy-text {
  color: #fff;
  line-height: 1.78;
  white-space: pre-wrap;
  word-break: break-word;
}

.scheduled-prompts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 10rpx;
  color: rgba(232, 238, 255, 0.72);
  font-size: 24rpx;
}

.copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 88rpx;
  height: 50rpx;
  margin: 0;
  padding: 0;
  color: #fff;
  background: rgba(255,255,255,0.16);
  border: 1rpx solid rgba(255,255,255,0.18);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.reference-row {
  display: flex;
  align-items: center;
}

.reference-img,
.reference-empty {
  width: 146rpx;
  height: 146rpx;
  border-radius: 18rpx;
}

.reference-img {
  background: rgba(255,255,255,0.08);
}

.reference-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(226, 232, 240, 0.48);
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  font-size: 23rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 28rpx;
}

.meta-grid view {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.meta-grid text:first-child {
  color: rgba(226, 232, 240, 0.48);
  font-size: 23rpx;
}

.meta-grid text:last-child {
  min-width: 0;
  color: rgba(255,255,255,0.82);
  text-align: right;
  font-size: 23rpx;
  font-weight: 800;
}

.bottom-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin: 0;
  padding: 0 12rpx;
  color: #10f5dd;
  background: rgba(5, 8, 12, 0.9);
  border: 1rpx solid rgba(255,255,255,0.13);
  border-radius: 22rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.action-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, rgba(16,245,221,0.36), rgba(14, 116, 144, 0.68));
  border-color: rgba(16,245,221,0.56);
  box-shadow: 0 0 28rpx rgba(16,245,221,0.18);
}

.action-btn[disabled] {
  color: rgba(226, 232, 240, 0.46);
  background: rgba(255,255,255,0.06);
  border-color: rgba(255,255,255,0.1);
}

.empty-card {
  margin-top: 40rpx;
  padding: 70rpx 24rpx;
  color: rgba(226, 232, 240, 0.62);
  text-align: center;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 28rpx;
  font-size: 26rpx;
}
