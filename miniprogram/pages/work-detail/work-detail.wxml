<view class="detail-page">
  <view class="space-layer stars-a"></view>
  <view class="space-layer stars-b"></view>

  <view class="detail-head">
    <button class="back-btn" bindtap="goBack">‹</button>
    <text class="detail-title">作品详情</text>
  </view>

  <block wx:if="{{work}}">
    <block wx:if="{{work.is_scheduled_run}}">
      <view class="params-card">
        <text class="card-title">{{work.title}}</text>
        <view class="meta-grid">
          <view>
            <text>状态</text>
            <text>{{work.status_label}}</text>
          </view>
          <view>
            <text>创建时间</text>
            <text>{{work.created_at_text || '--'}}</text>
          </view>
        </view>
        <text wx:if="{{work.result_text}}" class="field-label">结果</text>
        <view wx:if="{{work.result_text}}" class="field-box prompt-box">
          <text>{{work.result_text}}</text>
        </view>
      </view>
      <view wx:for="{{work.groups}}" wx:key="title" class="params-card">
        <text class="card-title">{{item.title}}</text>
        <view wx:for="{{item.records}}" wx:for-item="rec" wx:key="title" class="field-box prompt-box scheduled-record-box {{rec.is_moments ? 'moments-record-box' : ''}}">
          <text class="field-label">{{rec.title}}</text>
          <text class="{{rec.is_moments ? 'moments-copy-text' : ''}}">{{rec.body}}</text>
          <view wx:if="{{rec.prompts.length}}" class="scheduled-prompts">
            <text wx:for="{{rec.prompts}}" wx:for-item="prompt" wx:key="*this">配图：{{prompt}}</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
    <view class="player-panel">
      <video wx:if="{{work.playable_url}}" class="work-video" src="{{work.playable_url}}" controls show-fullscreen-btn show-play-btn object-fit="contain"></video>
      <view wx:else class="video-waiting">
        <image wx:if="{{work.cover_url}}" src="{{work.cover_url}}" mode="aspectFill" />
        <view class="waiting-mask">
          <text>{{work.status_label}}</text>
          <text>{{work.is_processing ? '预计5-10分钟' : (work.message || '视频暂不可播放')}}</text>
        </view>
      </view>
    </view>

    <view class="params-card">
      <text class="card-title">创作参数</text>

      <text class="field-label">作品名称</text>
      <view class="field-box">
        <text>{{work.title}}</text>
      </view>

      <text class="field-label">提示词</text>
      <view class="field-box prompt-box">
        <text>{{work.prompt || '暂无提示词'}}</text>
        <button wx:if="{{work.prompt}}" class="copy-btn" bindtap="copyPrompt">复制</button>
      </view>

      <text class="field-label">参考图片</text>
      <view class="reference-row">
        <image wx:if="{{work.cover_url}}" class="reference-img" src="{{work.cover_url}}" mode="aspectFill" />
        <view wx:else class="reference-empty">暂无</view>
      </view>

      <view class="meta-grid">
        <view>
          <text>状态</text>
          <text>{{work.status_label}}</text>
        </view>
        <view>
          <text>时长</text>
          <text>{{work.duration_text}}</text>
        </view>
        <view>
          <text>创建时间</text>
          <text>{{work.created_at_text || '--'}}</text>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="action-btn" bindtap="regenerate">↻ 重新生成</button>
      <button class="action-btn primary" loading="{{loading}}" bindtap="saveVideo">⬇ 下载</button>
      <button class="action-btn" open-type="share" disabled="{{!isSharedView && !shareToken}}" bindtap="onShareTap">{{!isSharedView && !shareToken ? '准备中' : '⌯ 分享'}}</button>
    </view>
    </block>
  </block>

  <view wx:else class="empty-card">
    <text>{{loading ? '正在加载作品...' : '未找到作品'}}</text>
  </view>
</view>
