page {
  min-height: 100vh;
  color: #0f172a;
  background: #f3f6fb;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 0;
  font-size: 28rpx;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx;
  color: #fff;
  background: linear-gradient(135deg, #07101f 0%, #133d7a 58%, #14b8a6 100%);
  border-radius: 28rpx;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.18);
}

.hero::after {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
}

.hero-title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 46rpx;
  font-weight: 800;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.6;
}

.section {
  margin-top: 26rpx;
  padding: 28rpx;
  background: #fff;
  border: 1rpx solid #e5eaf3;
  border-radius: 24rpx;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.muted {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.status-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #334155;
  font-size: 27rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #94a3b8;
}

.dot.ok {
  background: #22c55e;
}

.dot.warn {
  background: #f59e0b;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

.primary-btn {
  color: #fff;
  background: linear-gradient(135deg, #2563eb, #06b6d4);
}

.ghost-btn {
  color: #1d4ed8;
  background: #eff6ff;
}

.danger-btn {
  color: #b91c1c;
  background: #fee2e2;
}

.button-row {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.button-row button {
  flex: 1;
}

.input {
  width: 100%;
  height: 86rpx;
  padding: 0 24rpx;
  color: #0f172a;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.empty {
  padding: 60rpx 24rpx;
  color: #64748b;
  text-align: center;
  font-size: 27rpx;
}

